# Evonic LLM Evaluator - Environment Variables
# Copy this file to .env and fill in your values

# LLM Configuration (OpenAI-compatible endpoint)
# For OpenRouter: https://openrouter.ai/api/v1
# For local LLM (llama.cpp, Ollama, etc): http://localhost:8080/v1
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=qwen/qwen-3.5-4B
LLM_TIMEOUT=120
LLM_MAX_TOKENS=32768
LLM_CONTEXT_LENGTH=0
LLM_PROMPT_BUFFER=2048

# Two-Pass Extraction (PASS1: generate answer, PASS2: extract final answer)
TWO_PASS_ENABLED=1
TWO_PASS_TEMPERATURE=0.0

# Anthropic API (for improver module - analysis & training data generation)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Flask Configuration
SECRET_KEY=your-secret-key-here
HOST=0.0.0.0
PORT=8080
DEBUG=1

# Authentication
# Use `./evonic pass` to set new password.
ADMIN_PASSWORD_HASH=
# Cloudflare Turnstile (optional, shown on login page when configured)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Real-time Log Verbosity (set to 1 to include full content in live logs)
LOG_FULL_THINKING=0
LOG_FULL_RESPONSE=0

# Raw LLM API call logging (writes every request/response to markdown file)
LLM_API_LOG_ENABLED=0
LLM_API_LOG_FILE=logs/llm_api_calls.md

# Event stream log file (agent runtime events: processing_started, llm_thinking, tool_executed, etc.)
EVENT_LOG_FILE=logs/events.log

# Suppress noisy third-party logs from console (still written to log files).
# Comma-separated fnmatch patterns (e.g. apscheduler.*, telethon.*)
EVONIC_LOG_CONSOLE_QUIET=apscheduler.*

# Sub-agent idle TTL in seconds (default: 1800 = 30 minutes, configurable via env)
EVONIC_SUBAGENT_IDLE_TTL=1800

# Session Archive: when enabled the session data will be archived before it deleted in active db
EVONIC_SESSION_ARCHIVE=0

# Boot-gate probe: set to 1 to make `import app` return immediately without starting
# channels, the scheduler, or app.run(). Used by the update pipeline's smoke test to
# verify the new code imports cleanly without touching the live server's port or DB
# connections. Not intended for production use.
# EVONIC_SMOKE_TEST=

# Memory engine: "evomem" (default, graph-backed; requires the evomem binary) or
# "fts5" (SQLite full-text fallback, no binary needed). The installer fetches the
# evomem binary automatically; otherwise run `evonic evomem install`. When evomem
# is selected but the binary is absent, the runtime transparently uses FTS5.
EVONIC_MEMORY_ENGINE=evomem
# Pin a specific evomem release tag (default: latest). e.g. EVOMEM_VERSION=v0.2.0
# EVOMEM_VERSION=
# Override the evomem binary path (default: shared/bin/evomem).
# EVOMEM_BINARY=
